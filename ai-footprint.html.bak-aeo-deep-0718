<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0a0e1a;--card:#111827;--border:#1f2937;--text:#e5e7eb;--dim:#9ca3af;--blue:#3b82f6;--green:#10b981;--purple:#8b5cf6;--gold:#f59e0b;--red:#ef4444;--cyan:#06b6d4}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Noto Sans TC",sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding:2rem 1rem}
.container{max-width:1000px;margin:0 auto}
h1{font-size:1.8rem;font-weight:700;margin-bottom:.5rem;background:linear-gradient(135deg,var(--cyan),var(--blue));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.subtitle{color:var(--dim);margin-bottom:2rem;font-size:.9rem}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:2rem}
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.5rem;transition:border-color .2s}
.card:hover{border-color:var(--cyan)}
.card-title{color:var(--dim);font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem}
.card-value{font-size:2rem;font-weight:700;line-height:1}
.card-sub{color:var(--dim);font-size:.8rem;margin-top:.4rem}
.section{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.5rem;margin-bottom:1.5rem}
.section h2{font-size:.95rem;margin-bottom:1rem;color:var(--cyan);display:flex;align-items:center;gap:.5rem}
table{width:100%;border-collapse:collapse}
th{text-align:left;color:var(--dim);font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;padding:.5rem;border-bottom:1px solid var(--border)}
td{padding:.7rem .5rem;border-bottom:1px solid var(--border);font-size:.88rem}
tr:last-child td{border-bottom:none}
tr:hover td{background:#ffffff05}
.badge{display:inline-block;padding:.15rem .5rem;border-radius:20px;font-size:.7rem;font-weight:600}
.b-openai{background:#10589620;color:#60a5fa;border:1px solid #10589640}
.b-anthropic{background:#7c3aed20;color:#a78bfa;border:1px solid #7c3aed40}
.b-google{background:#059a4520;color:#34d399;border:1px solid #059a4540}
.b-ms{background:#0ea5e920;color:#38bdf8;border:1px solid #0ea5e940}
.b-other{background:#374151;color:var(--dim);border:1px solid #4b5563}
.status{display:flex;align-items:center;gap:.75rem;margin-bottom:1.5rem;padding:.75rem 1rem;background:var(--card);border:1px solid var(--border);border-radius:8px}
.dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse 2s infinite;flex-shrink:0}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}
.bar{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:.5rem}
.bar-fill{height:100%;border-radius:2px;transition:width .6s ease}
.num{font-variant-numeric:tabular-nums;font-feature-settings:"tnum"}
.logo{display:inline-flex;align-items:center;gap:.5rem;margin-bottom:1rem}
.logo-text{font-size:1rem;font-weight:600;color:var(--cyan);letter-spacing:.02em}
footer{text-align:center;padding:2rem 0 1rem;color:var(--dim);font-size:.8rem}
footer a{color:var(--cyan);text-decoration:none}
.no-worker{background:#7c3aed15;border:1px solid #7c3aed40;border-radius:8px;padding:1rem;margin-bottom:1.5rem;color:#a78bfa;font-size:.85rem}
</style>
</head>
<body>
<div class="container">
  <div class="status">
    <div class="dot" id="status-dot"></div>
    <div style="flex:1">
      <span style="color:var(--green);font-weight:600;font-size:.9rem" id="status-text">即時追蹤中</span>
      <span style="color:var(--dim);font-size:.8rem;margin-left:.75rem" id="last-update">連接中...</span>
    </div>
    <span style="color:var(--dim);font-size:.75rem">每60秒自動更新</span>
  </div>

  <div class="logo"><span class="logo-text">CloudPipe</span></div>
  <h1>AI 足跡追蹤儀表板</h1>
  <p class="subtitle">即時記錄哪些 AI 系統正在閱讀 CloudPipe — GPTBot、ClaudeBot、PerplexityBot 等 18 種 AI 爬蟲</p>

  <div id="no-worker-msg" class="no-worker" style="display:none">
    Cloudflare Worker 尚未連接。請部署 <code>cloudpipe-ai-tracker</code> Worker 後即可開始追蹤。
  </div>

  <div class="grid">
    <div class="card">
      <div class="card-title">今日 AI 訪問</div>
      <div class="card-value num" id="today-total" style="color:var(--cyan)">—</div>
      <div class="card-sub" id="today-label">載入中</div>
    </div>
    <div class="card">
      <div class="card-title">累積 AI 訪問</div>
      <div class="card-value num" id="total-visits" style="color:var(--green)">—</div>
      <div class="card-sub">所有時間</div>
    </div>
    <div class="card">
      <div class="card-title">AI 種類</div>
      <div class="card-value num" id="bot-count" style="color:var(--purple)">—</div>
      <div class="card-sub">已偵測系統 / 支援 18 種</div>
    </div>
    <div class="card">
      <div class="card-title">最活躍 AI</div>
      <div class="card-value" id="top-bot" style="color:var(--gold);font-size:1rem;padding-top:.3rem">—</div>
      <div class="card-sub" id="top-count">今日最多訪問</div>
    </div>
  </div>

  <div class="section">
    <h2>各 AI 系統訪問統計</h2>
    <table>
      <thead><tr><th>AI 系統</th><th>今日</th><th>累積</th><th>佔比</th><th>類型</th></tr></thead>
      <tbody id="bot-table"><tr><td colspan="5" style="color:var(--dim);text-align:center;padding:2rem">載入中...</td></tr></tbody>
    </table>
  </div>

  <div class="section">
    <h2>最近訪問記錄</h2>
    <table>
      <thead><tr><th>時間</th><th>AI 系統</th><th>訪問頁面</th><th>來源</th></tr></thead>
      <tbody id="visit-log"><tr><td colspan="4" style="color:var(--dim);text-align:center;padding:2rem">載入中...</td></tr></tbody>
    </table>
  </div>

  <footer>
    <address style="font-style:normal;font-size:12px;color:var(--dim)">
      <strong>CloudPipe</strong> &middot; AI Automation Platform<br>
      GitHub：<a href="https://github.com/Inari-Kira-Isla/cloudpipe-landing" style="color:var(--cyan)">Inari-Kira-Isla/cloudpipe-landing</a>
    </address>
    <p style="margin-top:.5rem">數據來源：Cloudflare Worker @ <code id="worker-host">cloudpipe-ai-tracker.inariglobal.workers.dev</code> | KV 儲存保留 30 天</p>
    <p style="margin-top:.5rem"><a href="/">← 返回 CloudPipe 首頁</a> · <a href="/ai-footprint.html">重新整理</a></p>
    <p style="margin-top:.5rem">&copy; 2026 CloudPipe &middot; CC BY 4.0</p>
  </footer>
</div>

<script>
// Worker URL — update after deployment
const WORKER = "https://cloudpipe-ai-tracker.inariglobal.workers.dev";

const BOT_META = {
  "OpenAI GPT": {cls:"b-openai", label:"OpenAI"},
  "ChatGPT Browser": {cls:"b-openai", label:"OpenAI"},
  "OpenAI Search": {cls:"b-openai", label:"OpenAI"},
  "Anthropic Claude": {cls:"b-anthropic", label:"Anthropic"},
  "Claude Crawler": {cls:"b-anthropic", label:"Anthropic"},
  "Claude Web": {cls:"b-anthropic", label:"Anthropic"},
  "Perplexity AI": {cls:"b-other", label:"Perplexity"},
  "Google Gemini Training": {cls:"b-google", label:"Google"},
  "Google Search": {cls:"b-google", label:"Google"},
  "Microsoft Bing AI": {cls:"b-ms", label:"Microsoft"},
  "ByteDance AI": {cls:"b-other", label:"ByteDance"},
  "Common Crawl": {cls:"b-other", label:"Common Crawl"},
  "You.com AI": {cls:"b-other", label:"You.com"},
  "Cohere AI": {cls:"b-other", label:"Cohere"},
  "Apple AI": {cls:"b-other", label:"Apple"},
  "Meta AI": {cls:"b-other", label:"Meta"},
  "Meta AI Bot": {cls:"b-other", label:"Meta"},
  "Internet Archive": {cls:"b-other", label:"Archive"},
};

async function loadStats() {
  try {
    const r = await fetch(WORKER + "/ai-stats.json");
    if (!r.ok) throw new Error("fetch failed");
    const d = await r.json();

    document.getElementById("no-worker-msg").style.display = "none";
    document.getElementById("status-dot").style.background = "var(--green)";
    document.getElementById("status-text").textContent = "即時追蹤中";
    document.getElementById("status-text").style.color = "var(--green)";

    const now = new Date(d.generatedAt);
    document.getElementById("last-update").textContent =
      "更新：" + now.toLocaleTimeString("zh-TW") + " (" + now.toLocaleDateString("zh-TW") + ")";

    const todayEntries = Object.entries(d.today || {}).sort((a,b) => b[1]-a[1]);
    const totalEntries = Object.entries(d.totals || {}).sort((a,b) => b[1]-a[1]);
    const tt = todayEntries.reduce((s,[,v]) => s+v, 0);
    const ta = totalEntries.reduce((s,[,v]) => s+v, 0);
    const bc = totalEntries.filter(([,v]) => v > 0).length;
    const topName = todayEntries[0]?.[0] || "—";
    const topCnt = todayEntries[0]?.[1] || 0;

    document.getElementById("today-total").textContent = tt;
    document.getElementById("today-label").textContent = bc + " 種 AI 系統";
    document.getElementById("total-visits").textContent = ta;
    document.getElementById("bot-count").textContent = bc;
    document.getElementById("top-bot").textContent = topName;
    document.getElementById("top-count").textContent = "今日 " + topCnt + " 次訪問";

    const allBots = new Set([...Object.keys(d.today||{}), ...Object.keys(d.totals||{})]);
    const maxTotal = Math.max(...[...allBots].map(n => d.totals?.[n]||0), 1);
    const rows = [...allBots]
      .sort((a,b) => (d.totals?.[b]||0) - (d.totals?.[a]||0))
      .map(name => {
        const todayCnt = d.today?.[name] || 0;
        const totalCnt = d.totals?.[name] || 0;
        const pct = Math.round(totalCnt / maxTotal * 100);
        const meta = BOT_META[name] || {cls:"b-other", label:"AI"};
        return `<tr>
          <td><strong>${name}</strong></td>
          <td class="num">${todayCnt > 0 ? '<strong style="color:var(--cyan)">'+todayCnt+'</strong>' : '0'}</td>
          <td class="num">${totalCnt}</td>
          <td style="min-width:80px">
            <div class="bar"><div class="bar-fill" style="width:${pct}%;background:var(--cyan)"></div></div>
            <span style="font-size:.7rem;color:var(--dim)">${pct}%</span>
          </td>
          <td><span class="badge ${meta.cls}">${meta.label}</span></td>
        </tr>`;
      }).join("");
    document.getElementById("bot-table").innerHTML = rows ||
      "<tr><td colspan='5' style='color:var(--dim);text-align:center;padding:1.5rem'>尚無 AI 訪問記錄</td></tr>";

    const logs = [...(d.recentVisits||[])].reverse().slice(0,20).map(v => {
      const t = new Date(v.ts).toLocaleTimeString("zh-TW");
      const path = v.path.length > 40 ? v.path.substring(0,40)+"..." : v.path;
      return `<tr>
        <td style="color:var(--dim);white-space:nowrap">${t}</td>
        <td><strong>${v.bot}</strong></td>
        <td style="color:var(--dim);font-size:.82rem;font-family:monospace">${path}</td>
        <td style="color:var(--dim);font-size:.78rem">${v.ref ? v.ref.substring(0,30)+"..." : "—"}</td>
      </tr>`;
    }).join("");
    document.getElementById("visit-log").innerHTML = logs ||
      "<tr><td colspan='4' style='color:var(--dim);text-align:center;padding:1.5rem'>尚無訪問記錄</td></tr>";

  } catch(e) {
    console.error("Failed to load stats:", e);
    document.getElementById("no-worker-msg").style.display = "block";
    document.getElementById("status-dot").style.background = "var(--gold)";
    document.getElementById("status-text").textContent = "等待 Worker 部署";
    document.getElementById("status-text").style.color = "var(--gold)";
    document.getElementById("last-update").textContent = "";
    document.getElementById("bot-table").innerHTML =
      "<tr><td colspan='5' style='color:var(--dim);text-align:center;padding:1.5rem'>等待 Cloudflare Worker 連接...</td></tr>";
    document.getElementById("visit-log").innerHTML =
      "<tr><td colspan='4' style='color:var(--dim);text-align:center;padding:1.5rem'>等待 Cloudflare Worker 連接...</td></tr>";
  }
}

loadStats();
setInterval(loadStats, 60000);
</script>
<img src="https://client-ai-tracker.inariglobal.workers.dev/cloudpipe-landing/pixel.gif?p=/ai-footprint" width="1" height="1" alt="" loading="eager" style="position:absolute;left:-9999px">
</body>
</html>
